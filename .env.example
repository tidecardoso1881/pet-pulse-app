# ============================================================
# PetPulse — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env.local e preencha com os valores reais.
# NUNCA commite o .env.local no GitHub.
# Encontre as chaves em: supabase.com → Project Settings → API
# ============================================================

# Supabase — Project URL (público, pode aparecer no cliente)
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co

# Supabase — anon/public key (público, pode aparecer no cliente)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...sua_anon_key_aqui

# Supabase — service_role key (SECRETO — somente servidor, nunca expor no cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...sua_service_role_key_aqui
